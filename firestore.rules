rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}: owner can read own doc; update allowed but cannot touch server-managed fields
    // Admin SDK (token.admin == true) has full write access
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !(request.resource.data.keys().hasAny(['isPremium', 'premiumExpiresAt', 'strikes', 'isBanned']));
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // adminActions: audit log for premium state changes — only Admin SDK can write
    match /adminActions/{doc} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // waitingUsers/{uid}: only the authenticated owner can create/read/delete
    match /waitingUsers/{uid} {
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow read: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow update: if false;
    }

    // users/{uid}/conversations/{convId}: lightweight refs — owner can read, server-only writes
    match /users/{uid}/conversations/{convId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // rooms/{roomId}: client can read if authenticated; writes are server-only
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // conversations/{convId}: users can read if they are a participant
    // only server (Admin SDK) can write
    match /conversations/{convId} {
      allow read: if request.auth != null 
        && request.auth.uid in resource.data.participants;
      allow write: if false;
    }

    // messages/{conversationId}/chat/{messageId}: users can read if they are participants
    // only server (Admin SDK) can write
    match /messages/{conversationId}/chat/{messageId} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      allow write: if false;
    }
  }
}
