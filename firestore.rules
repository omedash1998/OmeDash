rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isValidTimestampField(field) {
      return field is timestamp && field <= request.time;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['uid', 'createdAt'])
        && request.resource.data.keys().hasOnly([
             'uid', 'createdAt', 'isPremium', 'isBanned',
             'reputation', 'onboardingComplete'
           ])
        && request.resource.data.uid == uid
        && request.resource.data.get('isPremium', false) == false
        && request.resource.data.get('isBanned', false) == false;
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isPremium', 'isBanned', 'reputation', 'strikes',
                     'bannedReason', 'bannedAt', 'bannedExpiresAt', 'unbannedAt',
                     'premium', 'premiumSince', 'premiumExpiresAt']) == false
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'lastLogin', 'gender', 'age', 'onboardingComplete',
              'countryName', 'countryCode', 'countryEmoji',
              'displayName', 'photoURL', 'lastRoomId',
              'countryPref', 'genderPref', 'updatedAt'
            ])
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(uid);
    }

    match /waitingUsers/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['uid','status','createdAt'])
        && request.resource.data.uid == uid
        && request.resource.data.status == 'waiting'
        && isValidTimestampField(request.resource.data.createdAt);
      allow delete: if isOwner(uid);
      allow update: if false;
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /conversations/{convId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['participants','createdAt'])
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessageAt','lastMessageText','title','metadata','deletedFor','historyDeletedFor']);

      allow delete: if false;

      match /messages/{messageId} {
        function convAllows(uid) {
          return uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        }

        allow read: if isSignedIn() && convAllows(request.auth.uid);

        allow create: if isSignedIn()
          && convAllows(request.auth.uid)
          && request.resource.data.keys().hasAll(['senderId','createdAt','text'])
          && request.resource.data.keys().hasOnly(['senderId','createdAt','text','edited','metadata'])
          && request.resource.data.senderId == request.auth.uid
          && isValidTimestampField(request.resource.data.createdAt)
          && request.resource.data.text is string;

        allow update: if isSignedIn()
          && convAllows(request.auth.uid)
          && resource.data.senderId == request.auth.uid
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.keys().hasOnly(['senderId','createdAt','text','edited','metadata']);

        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
